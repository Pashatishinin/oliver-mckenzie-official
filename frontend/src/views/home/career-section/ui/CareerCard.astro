---
interface Props {
    title: string;
    coverImageUrl: string | null;
    coverImageAlt: string;
    careerContent: string[];
    rotation?: number;
}

const {
    title,
    coverImageUrl,
    coverImageAlt,
    careerContent,
    rotation = 0,
} = Astro.props;
---

<div
    class="career-card relative flex flex-col w-[80vw] md:w-[33vw] min-h-100 md:min-h-125 shrink-0 rounded overflow-hidden shadow-2xl border border-white/10"
    style={`transform: rotate(${rotation}deg)`}
>
    <!-- Top stripe with title -->
    <div class="bg-(--color-text) px-3 py-2">
        <span
            class="text-(--color-background) text-xs font-black uppercase tracking-widest leading-none block truncate"
        >
            {title}
        </span>
    </div>

    <!-- Photo -->
    <div
        class="relative aspect-[4/5] overflow-hidden bg-black/20 max-h-48 md:max-h-72"
    >
        {
            coverImageUrl ? (
                <img
                    src={coverImageUrl}
                    alt={coverImageAlt}
                    class="w-full h-full object-cover"
                />
            ) : (
                <div class="w-full h-full bg-white/5" />
            )
        }
    </div>

    <!-- Stats / content -->
    <div
        class="bg-(--color-background) border-t border-white/20 px-3 py-3 flex flex-col gap-1"
    >
        <span
            class="text-[10px] uppercase tracking-[0.2em] opacity-40 font-semibold mb-1"
            >Experience</span
        >
        {
            careerContent.map((item) => (
                <span class="text-xs leading-snug opacity-80">— {item}</span>
            ))
        }
    </div>
</div>
