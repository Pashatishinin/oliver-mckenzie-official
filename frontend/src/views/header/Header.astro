---
import Button from "../../shared/ui/Button.astro";
// biome-ignore lint/correctness/noUnusedImports: used in template
import Menu from "./ui/Menu.astro";
---

<Menu />

<header
    class="fixed top-0 w-screen px-8 md:px-16 py-4 flex justify-between items-center z-99999"
>
    <a href="/" id="home-link" class="font-bold text-3xl tracking-tighter">OLI.</a>
    <Button id="menu-btn" label="Menu" />
</header>

<script>
    import gsap from "gsap";
    import ScrollToPlugin from "gsap/ScrollToPlugin";

    gsap.registerPlugin(ScrollToPlugin);

    document.getElementById("home-link")?.addEventListener("click", (e) => {
        if (window.location.pathname === "/") {
            e.preventDefault();
            gsap.to(window, {
                scrollTo: { y: "#hero-section", offsetY: 0 },
                duration: 1.2,
                ease: "power3.inOut",
            });
        }
    });

    const overlay = document.getElementById("menu-overlay");
    const menuBtn = document.getElementById("menu-btn");
    const menuLabel = menuBtn?.querySelector<HTMLElement>("span:last-of-type");
    let isOpen = false;

    function openMenu() {
        isOpen = true;
        overlay?.classList.remove("translate-x-full");
        if (menuLabel) menuLabel.textContent = "Close";
    }

    function closeMenu() {
        isOpen = false;
        overlay?.classList.add("translate-x-full");
        if (menuLabel) menuLabel.textContent = "Menu";
    }

    menuBtn?.addEventListener("click", () => {
        isOpen ? closeMenu() : openMenu();
    });

    overlay?.querySelectorAll(".menu-link").forEach((link) => {
        link.addEventListener("click", closeMenu);
    });
</script>
