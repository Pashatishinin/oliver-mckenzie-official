---
// biome-ignore lint/correctness/noUnusedImports: used in template
import NavLink from "../../shared/ui/NavLink.astro";

const isHome = Astro.url.pathname === "/";
---

<footer class="p-2 md:p-3 w-screen h-screen max-h-100">
    <div
        class="bg-[#edeeff] text-[#0a192f] w-full rounded-sm px-10 py-10 md:px-14 md:py-12 flex flex-col md:flex-row gap-10 relative overflow-hidden h-full"
    >
        <nav class="w-1/3">
            <ul class="flex flex-col gap-1">
                <li class="text-xs uppercase tracking-widest opacity-40 font-semibold mb-2">Menu</li>
                <li><NavLink href="/" label="Home" class="text-sm" /></li>
                {isHome && (
                    <>
                        <li><NavLink href="/#portfolio" label="Portfolio" class="text-sm" /></li>
                        <li><NavLink href="/#career" label="Career" class="text-sm" /></li>
                    </>
                )}
            </ul>
        </nav>

        <div class="flex flex-col gap-6">
            <div>
                <p class="text-xs uppercase tracking-widest opacity-40 font-semibold mb-1">Email</p>
                <NavLink href="mailto:olimckenzie22@live.co.uk" label="olimckenzie22@live.co.uk" class="text-sm" />
            </div>
            <div>
                <p class="text-xs uppercase tracking-widest opacity-40 font-semibold mb-1">Phone</p>
                <NavLink href="tel:+447909287345" label="+44 7909 287345" class="text-sm" />
            </div>
        </div>

        <span
            class="absolute right-6 bottom-6 md:right-10 md:bottom-8 text-[100px] md:text-[160px] font-bold tracking-tighter leading-none select-none pointer-events-none opacity-10"
        >
            OLI.
        </span>
    </div>
</footer>
